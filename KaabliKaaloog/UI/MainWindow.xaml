<Window
    x:Class="KaabliKataloog.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:KaabliKataloog"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Camera FOV"
    Width="1250"
    Height="600"
    MinWidth="200"
    MinHeight="185"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    mc:Ignorable="av">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  Material Design DataGrid theme  -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.DataGrid.xaml" />
                <!--  Material Design dark theme (design-time fallback)  -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <!--  Shared element styles  -->
                <ResourceDictionary Source="Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>


    <Grid Background="Transparent" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="14*" />

        </Grid.RowDefinitions>
        <!--  Outer Border with Opacity and Blur  -->
        <Border
            Grid.RowSpan="2"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2" />
            </Border.Effect>
        </Border>

        <!--  Content Container (Not Affected by Opacity/Blur)  -->
        <Border
            Grid.RowSpan="2"
            Margin="2,2,2,2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Custom Title Bar  -->
                <local:TitleBar
                    Grid.Row="0"
                    Margin="0,0,0,1"
                    Foreground="{DynamicResource ForegroundBrush}" />
                <Grid
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,100,0"
                    HorizontalAlignment="Right">
                    <ToggleButton
                        x:Name="ThemeToggleButton"
                        Width="28"
                        Height="15.5"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="ToggleTheme_Click"
                        DockPanel.Dock="Right"
                        IsChecked="True"
                        ToolTip="Toggle Theme">

                        <ToggleButton.Template>
                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                <Grid Background="Transparent">

                                    <materialDesign:PackIcon
                                        x:Name="ThemeToggleIcon"
                                        Width="30"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource IconBrush}"
                                        Kind="ToggleSwitchOffOutline" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOffOutline" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOutline" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
                <Grid
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="10,0,10,10"
                    HorizontalAlignment="Stretch">
                    <Border
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        ClipToBounds="True" />
                    <!--  Camera Resolution Dropdown  -->
                    <StackPanel
                        Margin="10"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top" />
                    <Grid Background="Transparent" ClipToBounds="True">
                        <!--  Outer Border with Opacity and Blur  -->
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2"
                            ClipToBounds="True"
                            CornerRadius="10"
                            Opacity="0.7"
                            SnapsToDevicePixels="True">
                            <Border.Effect>
                                <BlurEffect KernelType="Gaussian" Radius="2" />
                            </Border.Effect>
                        </Border>

                        <!--  Content Container  -->
                        <Border
                            Margin="0,0,0,0"
                            Background="{DynamicResource PrimaryBackgroundBrush}"
                            CornerRadius="10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>



                                <!--  🔹 Input Fields with Labels  -->
                                <Grid Grid.Column="0" Margin="0,5,20,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!--  Search Box  -->
                                    <Border
                                        Grid.Row="0"
                                        Height="26"
                                        Margin="0,0,0,8"
                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="26" />
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon
                                                Grid.Column="0"
                                                Width="14"
                                                Height="14"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource ForegroundBrush}"
                                                Kind="Magnify"
                                                Opacity="0.6" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="2,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                Foreground="#FF808080"
                                                IsHitTestVisible="False"
                                                Text="Otsi kaablit...">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding Text, ElementName=WireSearchBox}" Value="" />
                                                                    <Condition Binding="{Binding IsFocused, ElementName=WireSearchBox}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox
                                                x:Name="WireSearchBox"
                                                Grid.Column="1"
                                                Height="Auto"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="11"
                                                Foreground="{DynamicResource ForegroundBrush}"
                                                Style="{StaticResource CustomTextBoxStyle}"
                                                TextAlignment="Left"
                                                TextChanged="WireSearch_TextChanged" />
                                            <Button
                                                Grid.Column="2"
                                                Width="22"
                                                Height="22"
                                                Margin="0"
                                                Click="ClearWireSearch_Click"
                                                Style="{StaticResource FlatIconButton}"
                                                ToolTip="Tühjenda otsing">
                                                <materialDesign:PackIcon
                                                    Width="12"
                                                    Height="12"
                                                    Foreground="{DynamicResource ForegroundBrush}"
                                                    Kind="CloseCircleOutline"
                                                    Opacity="0.6" />
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                    <!--  🔹 ComboBox for "Voolujuhi materjal"  -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            Width="115"
                                            Margin="0,5,10,5"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            Text="Voolujuhi materjal:" />
                                        <ComboBox
                                            x:Name="MaterialComboBox"
                                            Width="96"
                                            Height="25"
                                            FontSize="12"
                                            SelectionChanged="MaterialComboBox_SelectionChanged"
                                            Style="{StaticResource DarkThemeComboBox}" />
                                    </StackPanel>

                                    <!--  🔹 ComboBox for "Tulereaktsiooni klass"  -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            Width="115"
                                            Margin="0,5,10,5"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            Text="Tulereaktsiooni klass:" />
                                        <ComboBox
                                            x:Name="ReactionClassComboBox"
                                            Width="96"
                                            Height="25"
                                            FontSize="12"
                                            SelectionChanged="ReactionClassComboBox_SelectionChanged"
                                            Style="{StaticResource DarkThemeComboBox}" />
                                    </StackPanel>

                                    <!--  🔹 Checkbox for "UV-kindel"  -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            Width="115"
                                            Margin="0,5,10,5"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            Text="UV-kindel:" />
                                        <CheckBox
                                            x:Name="UvKindelCheckBox"
                                            Margin="40.5,0,0,0"
                                            VerticalAlignment="Center"
                                            Checked="OnInputChanged"
                                            IsChecked="False"
                                            Style="{StaticResource CustomCheckBox}"
                                            Unchecked="OnInputChanged" />
                                    </StackPanel>

                                    <!--  🔹 Checkbox for "Koos kaitsejuhiga"  -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            Width="115"
                                            Margin="0,5,10,5"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            Text="Koos kaitsejuhiga:" />
                                        <CheckBox
                                            x:Name="KoosKaitsejuhigaCheckBox"
                                            Margin="40.5,0,0,0"
                                            VerticalAlignment="Center"
                                            Checked="OnInputChanged"
                                            IsChecked="True"
                                            Style="{StaticResource CustomCheckBox}"
                                            Unchecked="OnInputChanged" />
                                    </StackPanel>

                                    <!--  🔹 ComboBox for "Soonte arv"  -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            Width="115"
                                            Margin="0,5,10,5"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            Text="Soonte arv:" />
                                        <ComboBox
                                            x:Name="ConductorCountComboBox"
                                            Width="96"
                                            Height="25"
                                            FontSize="12"
                                            SelectionChanged="ConductorCountComboBox_SelectionChanged"
                                            Style="{StaticResource DarkThemeComboBox}" />
                                    </StackPanel>

                                    <!--  🔹 ComboBox for "Juhi ristlõige(mm²)"  -->
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <TextBlock
                                            Width="115"
                                            Margin="0,5,10,5"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            Text="Juhi ristlõige (mm²):" />
                                        <ComboBox
                                            x:Name="WireSizeComboBox"
                                            Width="96"
                                            Height="25"
                                            FontSize="12"
                                            SelectionChanged="OnInputChanged"
                                            Style="{StaticResource DarkThemeComboBox}" />
                                    </StackPanel>
                                    <Button
                                        x:Name="CreateWireTypesButton"
                                        Margin="0,15,0,0"
                                        HorizontalAlignment="Center"
                                        Click="CreateWireTypesButton_Click"
                                        Content="Loo Revitis tüübid"
                                        Style="{StaticResource CustomActionButtonStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="3"
                                        Margin="0,6,0,4"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                        <Button
                                            x:Name="EditCatalogueButton"
                                            Width="80"
                                            Height="28"
                                            Margin="0,0,6,0"
                                            Click="EditCatalogueButton_Click"
                                            Content="Muuda"
                                            FontSize="11"
                                            Style="{StaticResource CustomActionButtonStyle}" />
                                        <Button
                                            x:Name="DeleteButton"
                                            Width="80"
                                            Height="28"
                                            Margin="0"
                                            Click="DeleteButton_Click"
                                            Content="Kustuta"
                                            FontSize="11"
                                            Style="{StaticResource CustomActionButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                                <!--  🔹 Wire List Table - RIGHT Column  -->
                                <DataGrid
                                    x:Name="WireDataGrid"
                                    Grid.Column="1"
                                    Margin="0,0,0,0"
                                    AutoGenerateColumns="False"
                                    Background="{DynamicResource PrimaryBackgroundBrush}"
                                    CanUserResizeColumns="True"
                                    CanUserSortColumns="True"
                                    ColumnHeaderStyle="{StaticResource CustomDataGridColumnHeaderStyle}"
                                    FontSize="10"
                                    Foreground="{DynamicResource ForegroundBrush}"
                                    GridLinesVisibility="All"
                                    HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                    IsReadOnly="False"
                                    ItemsSource="{Binding FilteredWireResults}"
                                    RowHeaderWidth="0"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    Style="{StaticResource CustomDataGridStyle}"
                                    VerticalGridLinesBrush="{DynamicResource BorderBrush}">

                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="30" Header="✓" IsReadOnly="True">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        IsChecked="{Binding Path=IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Style="{StaticResource DatagridCheckboxStyle}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>



                                        <DataGridTemplateColumn Header="Nimi" IsReadOnly="True">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox
                                                        Padding="2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="IBeam"
                                                        FontSize="10"
                                                        Foreground="{DynamicResource ForegroundBrush}"
                                                        IsReadOnly="True"
                                                        Text="{Binding DisplayName, Mode=OneWay}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Binding="{Binding WireName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Tüüp" />
                                        <DataGridTextColumn Binding="{Binding Material, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Materjal" />
                                        <DataGridTextColumn Binding="{Binding FireReactionClass, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Klass" />
                                        <DataGridTextColumn Binding="{Binding HalogenFree, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Halogeenivaba" />
                                        <DataGridTextColumn Binding="{Binding ConductorCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Soonte arv" />
                                        <DataGridTextColumn Binding="{Binding WireSize, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Juhi ristlõige" />
                                        <DataGridTextColumn Binding="{Binding UvKindel, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="UV Kindel" />
                                        <DataGridTextColumn Binding="{Binding KoosKaitsejuhiga, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Kaitsejuht" />
                                        <DataGridTextColumn Binding="{Binding Välisläbimõõt, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Diameeter" />
                                        <DataGridTextColumn Binding="{Binding Painderaadius, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Painderaadius (mm)" />
                                        <DataGridTextColumn Binding="{Binding CurrentCapacity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" Header="Koormusvool (A)" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>